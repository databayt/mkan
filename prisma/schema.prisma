generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Application {
  id              Int               @id @default(autoincrement())
  applicationDate DateTime
  status          ApplicationStatus
  propertyId      Int
  tenantId        String
  name            String
  email           String
  phoneNumber     String
  message         String?
  leaseId         Int?              @unique
  lease           Lease?            @relation(fields: [leaseId], references: [id])
  listing         Listing           @relation(fields: [propertyId], references: [id])
  tenant          Tenant            @relation(fields: [tenantId], references: [userId])

  @@index([tenantId])
  @@index([status])
  @@index([propertyId, tenantId])
  @@index([status, applicationDate])
}

model AssemblyPoint {
  id                  Int               @id @default(autoincrement())
  name                String
  nameAr              String?
  address             String
  city                String
  latitude            Float
  longitude           Float
  isActive            Boolean           @default(true)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  routesAsDestination Route[]           @relation("Route_destinationIdToAssemblyPoint")
  routesAsOrigin      Route[]           @relation("Route_originIdToAssemblyPoint")
  transportOffices    TransportOffice[]
  rideDrivers         RideDriver[]

  @@index([city, isActive])
}

// ─── Homes Vertical ─────────────────────────────────────────────────────────

model Booking {
  id              Int           @id @default(autoincrement())
  listingId       Int
  guestId         String
  checkIn         DateTime
  checkOut        DateTime
  guestCount      Int
  nightlyRate     Float
  nightsCount     Int
  subtotal        Float
  cleaningFee     Float         @default(0)
  serviceFee      Float         @default(0)
  weeklyDiscount  Float         @default(0)
  monthlyDiscount Float         @default(0)
  totalPrice      Float
  status          BookingStatus @default(Pending)
  specialRequests String?
  confirmedAt     DateTime?
  cancelledAt     DateTime?
  checkedInAt     DateTime?
  checkedOutAt    DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  listing Listing @relation(fields: [listingId], references: [id])
  guest   User    @relation(fields: [guestId], references: [id])
  review  Review?

  @@index([listingId])
  @@index([guestId])
  @@index([status])
  @@index([listingId, status])
  @@index([listingId, checkIn, checkOut])
  @@index([checkIn, checkOut])
}

model Review {
  id            Int       @id @default(autoincrement())
  listingId     Int
  bookingId     Int       @unique
  reviewerId    String
  rating        Int
  comment       String?
  cleanliness   Float?
  accuracy      Float?
  checkIn       Float?
  communication Float?
  location      Float?
  value         Float?
  hostReply     String?
  hostRepliedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  listing  Listing @relation(fields: [listingId], references: [id])
  booking  Booking @relation(fields: [bookingId], references: [id])
  reviewer User    @relation(fields: [reviewerId], references: [id])

  @@index([listingId])
  @@index([listingId, rating])
  @@index([reviewerId])
}

model BlockedDate {
  id        Int      @id @default(autoincrement())
  listingId Int
  startDate DateTime
  endDate   DateTime
  reason    String?
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, startDate, endDate])
}

model SeasonalPricing {
  id            Int      @id @default(autoincrement())
  listingId     Int
  name          String?
  startDate     DateTime
  endDate       DateTime
  pricePerNight Float
  minStay       Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, startDate, endDate])
}

model Bus {
  id           Int             @id @default(autoincrement())
  plateNumber  String          @unique
  model        String?
  manufacturer String?
  year         Int?
  capacity     Int
  photoUrls    String[]        @default([])
  amenities    BusAmenity[]    @default([])
  seatLayout   Json?
  officeId     Int
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  office       TransportOffice @relation(fields: [officeId], references: [id])
  trips        Trip[]

  @@index([officeId])
}

model Lease {
  id          Int          @id @default(autoincrement())
  startDate   DateTime
  endDate     DateTime
  rent        Float
  deposit     Float
  propertyId  Int
  tenantId    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  application Application?
  listing     Listing      @relation(fields: [propertyId], references: [id])
  tenant      Tenant       @relation(fields: [tenantId], references: [userId])
  payments    Payment[]

  @@index([tenantId])
  @@index([propertyId])
}

model Listing {
  id                 Int                 @id @default(autoincrement())
  title              String?
  description        String?
  pricePerNight      Float?
  securityDeposit    Float?
  applicationFee     Float?
  photoUrls          String[]            @default([])
  amenities          Amenity[]           @default([])
  highlights         Highlight[]         @default([])
  isPetsAllowed      Boolean             @default(false)
  isParkingIncluded  Boolean             @default(false)
  bedrooms           Int?
  bathrooms          Float?
  squareFeet         Int?
  guestCount         Int                 @default(2)
  propertyType       PropertyType?
  postedDate         DateTime?
  averageRating      Float?              @default(0)
  numberOfReviews    Int?                @default(0)
  draft              Boolean             @default(true)
  isPublished        Boolean             @default(false)
  instantBook        Boolean             @default(false)
  locationId         Int?
  hostId             String
  // Homes vertical fields
  cleaningFee        Float?              @default(0)
  weeklyDiscount     Float?              @default(0)
  monthlyDiscount    Float?              @default(0)
  cancellationPolicy CancellationPolicy? @default(Flexible)
  checkInTime        String?
  checkOutTime       String?
  checkInMethod      CheckInMethod?
  houseRules         Json?
  minStay            Int?                @default(1)
  maxStay            Int?                @default(365)
  advanceNotice      Int?                @default(1)
  preparationTime    Int?                @default(0)
  availabilityWindow Int?                @default(12)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  location        Location?         @relation(fields: [locationId], references: [id])
  host            User              @relation(fields: [hostId], references: [id])
  leases          Lease[]
  applications    Application[]
  favoritedBy     Tenant[]          @relation("TenantFavorites")
  tenants         Tenant[]          @relation("TenantProperties")
  bookings        Booking[]
  reviews         Review[]
  blockedDates    BlockedDate[]
  seasonalPricing SeasonalPricing[]

  @@index([hostId])
  @@index([hostId, isPublished])
  @@index([isPublished, draft])
  @@index([isPublished, draft, postedDate])
  @@index([isPublished, draft, pricePerNight])
  @@index([propertyType])
  @@index([pricePerNight])
  @@index([guestCount])
}

model Location {
  id         Int       @id @default(autoincrement())
  address    String
  city       String
  state      String
  country    String
  postalCode String
  latitude   Float
  longitude  Float
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  listings   Listing[]

  @@index([city, state])
  @@index([country])
  @@index([latitude, longitude])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model Payment {
  id            Int           @id @default(autoincrement())
  amountDue     Float
  amountPaid    Float
  dueDate       DateTime
  paymentDate   DateTime
  paymentStatus PaymentStatus
  leaseId       Int
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  lease         Lease         @relation(fields: [leaseId], references: [id])

  @@index([leaseId])
  @@index([paymentStatus])
  @@index([dueDate])
}

// ─── Rides Vertical ─────────────────────────────────────────────────────────

model RideDriver {
  id              Int            @id @default(autoincrement())
  userId          String         @unique
  vehicleType     VehicleType
  vehiclePlate    String
  vehicleModel    String?
  vehicleColor    String?
  assemblyPointId Int?
  isActive        Boolean        @default(true)
  isVerified      Boolean        @default(false)
  rating          Float          @default(5.0)
  reviewCount     Int            @default(0)
  phone           String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user          User           @relation(fields: [userId], references: [id])
  assemblyPoint AssemblyPoint? @relation(fields: [assemblyPointId], references: [id])
  rides         Ride[]

  @@index([assemblyPointId])
  @@index([isActive, isVerified])
}

model Ride {
  id                  Int               @id @default(autoincrement())
  transportBookingId  Int?              @unique
  passengerId         String
  passengerName       String
  passengerPhone      String
  driverId            Int?
  pickupAddress       String
  pickupLat           Float
  pickupLng           Float
  dropoffAddress      String
  dropoffLat          Float
  dropoffLng          Float
  vehicleType         VehicleType
  scheduledTime       DateTime
  estimatedDuration   Int?
  estimatedDistance    Float?
  price               Float
  status              RideStatus        @default(Requested)
  acceptedAt          DateTime?
  startedAt           DateTime?
  completedAt         DateTime?
  cancelledAt         DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  transportBooking TransportBooking? @relation(fields: [transportBookingId], references: [id])
  passenger        User              @relation("RidePassenger", fields: [passengerId], references: [id])
  driver           RideDriver?       @relation(fields: [driverId], references: [id])

  @@index([passengerId])
  @@index([driverId])
  @@index([status])
  @@index([scheduledTime])
}

// ─── Transport Vertical ─────────────────────────────────────────────────────

model Route {
  id            Int             @id @default(autoincrement())
  officeId      Int
  originId      Int
  destinationId Int
  basePrice     Float
  duration      Int
  distance      Float?
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  destination   AssemblyPoint   @relation("Route_destinationIdToAssemblyPoint", fields: [destinationId], references: [id])
  office        TransportOffice @relation(fields: [officeId], references: [id])
  origin        AssemblyPoint   @relation("Route_originIdToAssemblyPoint", fields: [originId], references: [id])
  trips         Trip[]

  @@unique([officeId, originId, destinationId])
  @@index([officeId])
  @@index([officeId, isActive])
  @@index([originId, destinationId, isActive])
}

model Seat {
  id             Int               @id @default(autoincrement())
  tripId         Int
  seatNumber     String
  row            Int
  column         Int
  seatType       String?
  status         SeatStatus        @default(Available)
  bookingId      Int?
  reservedUntil  DateTime?
  booking        TransportBooking? @relation(fields: [bookingId], references: [id])
  trip           Trip              @relation(fields: [tripId], references: [id])

  @@unique([tripId, seatNumber])
  @@index([tripId, status])
  @@index([reservedUntil])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Tenant {
  id           Int           @id @default(autoincrement())
  userId       String        @unique
  name         String
  email        String
  phoneNumber  String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
  leases       Lease[]
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  favorites    Listing[]     @relation("TenantFavorites")
  properties   Listing[]     @relation("TenantProperties")
}

model TransportBooking {
  id               Int                    @id @default(autoincrement())
  bookingReference String                 @unique
  userId           String
  tripId           Int
  officeId         Int
  passengerName    String
  passengerPhone   String
  passengerEmail   String?
  totalAmount      Float
  status           TransportBookingStatus @default(Pending)
  qrCode           String?
  ticketUrl        String?
  bookedAt         DateTime               @default(now())
  confirmedAt      DateTime?
  cancelledAt      DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  seats            Seat[]
  office           TransportOffice        @relation(fields: [officeId], references: [id])
  trip             Trip                   @relation(fields: [tripId], references: [id])
  user             User                   @relation(fields: [userId], references: [id])
  payments         TransportPayment[]
  ride             Ride?

  @@index([userId])
  @@index([status])
  @@index([tripId])
}

model TransportOffice {
  id              Int                @id @default(autoincrement())
  name            String
  nameAr          String?
  description     String?
  descriptionAr   String?
  logoUrl         String?
  phone           String
  email           String
  licenseNumber   String?            @unique
  ownerId         String
  assemblyPointId Int?
  isVerified      Boolean            @default(false)
  isActive        Boolean            @default(false)
  rating          Float?             @default(0)
  reviewCount     Int                @default(0)
  // Per-office payment instructions for bank transfer + mobile money. Empty
  // strings are allowed during onboarding; UI hides the section when blank
  // so a guest never sees an empty bank-transfer card.
  bankName        String             @default("")
  bankAccount     String             @default("")
  bankHolder      String             @default("")
  momoNumber      String             @default("")
  momoProvider    String             @default("")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  buses           Bus[]
  routes          Route[]
  bookings        TransportBooking[]
  assemblyPoint   AssemblyPoint?     @relation(fields: [assemblyPointId], references: [id])
  owner           User               @relation(fields: [ownerId], references: [id])
}

/// Stripe webhook idempotency log. Insert by `eventId @unique` before
/// processing — second delivery of the same event short-circuits and the
/// route returns 200 without re-running side effects.
model WebhookEvent {
  id          Int      @id @default(autoincrement())
  provider    String
  eventId     String   @unique
  eventType   String
  payload     Json
  processedAt DateTime @default(now())

  @@index([provider, eventType])
}

/// Singleton platform-level configuration. We always read/write id = 1.
/// New settings get added as columns via a one-off migration so the type
/// surface stays explicit (much easier than a KV table when six different
/// admin pages read the same handful of values).
model PlatformSetting {
  id                        Int                @id @default(1)
  /// Percentage (0..1) of each booking the platform keeps. 0.10 = 10%.
  platformFeePct            Float              @default(0.10)
  /// Default cancellation policy when a host doesn't pick one explicitly.
  defaultCancellationPolicy CancellationPolicy @default(Flexible)
  /// Comma-separated ISO 4217 codes (e.g. "SDG,USD,SAR"). Empty = unrestricted.
  supportedCurrencies       String             @default("SDG,USD,SAR")
  /// How many days after booking the platform pays the host.
  payoutScheduleDays        Int                @default(30)
  /// Outbound email From: address (Resend / SES).
  emailFrom                 String             @default("")
  /// Where bug reports / billing questions go.
  supportEmail              String             @default("")
  updatedAt                 DateTime           @updatedAt
}

model TransportPayment {
  id            Int                    @id @default(autoincrement())
  bookingId     Int
  amount        Float
  method        TransportPaymentMethod
  status        TransportPaymentStatus @default(Pending)
  transactionId String?
  paidAt        DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  booking       TransportBooking       @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
}

model Trip {
  id             Int                @id @default(autoincrement())
  routeId        Int
  busId          Int
  departureDate  DateTime
  departureTime  String
  arrivalTime    String?
  price          Float
  availableSeats Int
  isActive       Boolean            @default(true)
  isCancelled    Boolean            @default(false)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  seats          Seat[]
  bookings       TransportBooking[]
  bus            Bus                @relation(fields: [busId], references: [id])
  route          Route              @relation(fields: [routeId], references: [id])

  @@index([departureDate])
  @@index([routeId, departureDate])
  @@index([isActive, isCancelled, departureDate])
  @@index([routeId, departureDate, departureTime])
}

model TwoFactorConfirmation {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TwoFactorToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model User {
  id                    String                 @id @default(cuid())
  username              String?                @unique
  email                 String                 @unique
  emailVerified         DateTime?
  image                 String?
  password              String?
  role                  UserRole               @default(USER)
  isTwoFactorEnabled    Boolean                @default(false)
  isSuspended           Boolean                @default(false)
  suspendedAt           DateTime?
  suspensionReason      String?
  lastLogin             DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  accounts              Account[]
  listings              Listing[]
  sessions              Session[]
  tenant                Tenant?
  transportBookings     TransportBooking[]
  transportOffices      TransportOffice[]
  twoFactorConfirmation TwoFactorConfirmation?
  // Homes
  bookings              Booking[]
  reviews               Review[]
  // Rides
  rideDriver            RideDriver?
  ridesAsPassenger      Ride[]                 @relation("RidePassenger")
}

model VerificationToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Amenity {
  WasherDryer
  AirConditioning
  Dishwasher
  HighSpeedInternet
  HardwoodFloors
  WalkInClosets
  Microwave
  Refrigerator
  Pool
  Gym
  Parking
  PetsAllowed
  WiFi
}

enum ApplicationStatus {
  Pending
  Denied
  Approved
}

enum BookingStatus {
  Pending
  Confirmed
  Cancelled
  Completed
  Declined
}

enum BusAmenity {
  AirConditioning
  WiFi
  USB
  LegRoom
  Toilet
  Refreshments
  Entertainment
  Luggage
  Reclining
}

enum CancellationPolicy {
  Flexible
  Moderate
  Firm
  Strict
  NonRefundable
}

enum CheckInMethod {
  SelfCheckIn
  InPerson
  Lockbox
  SmartLock
}

enum Highlight {
  HighSpeedInternetAccess
  WasherDryer
  AirConditioning
  Heating
  SmokeFree
  CableReady
  SatelliteTV
  DoubleVanities
  TubShower
  Intercom
  SprinklerSystem
  RecentlyRenovated
  CloseToTransit
  GreatView
  QuietNeighborhood
}

enum PaymentStatus {
  Pending
  Paid
  PartiallyPaid
  Overdue
}

enum PropertyType {
  Rooms
  Tinyhouse
  Apartment
  Villa
  Townhouse
  Cottage
}

enum RideStatus {
  Requested
  Accepted
  EnRoute
  Arrived
  InProgress
  Completed
  Cancelled
  NoShow
}

enum SeatStatus {
  Available
  Reserved
  Booked
  Blocked
}

enum TransportBookingStatus {
  Pending
  Confirmed
  Cancelled
  Completed
  NoShow
}

enum TransportPaymentMethod {
  MobileMoney
  CreditCard
  DebitCard
  CashOnArrival
  BankTransfer
}

enum TransportPaymentStatus {
  Pending
  Paid
  Refunded
  Failed
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  USER
  MANAGER
  TENANT
  DRIVER
}

enum VehicleType {
  Car
  Tuktuk
  Van
}
