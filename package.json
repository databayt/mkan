{
  "name": "mkan",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "predev": "tsx scripts/wake-db.ts",
    "dev": "next dev --turbopack -p 3000",
    "dev:kill": "lsof -ti:3000 | xargs kill -9 2>/dev/null; pnpm dev",
    "build": "prisma generate && tsx scripts/wake-db.ts && next build --webpack",
    "start": "next start -p 3000",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:strict": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "wake-db": "tsx scripts/wake-db.ts",
    "seed": "tsx seed.ts",
    "seed:admin": "tsx scripts/seed-admin.ts",
    "seed:listings": "tsx scripts/seed-listings.ts",
    "seed:test-user": "tsx scripts/seed-test-user.ts",
    "seed:transport": "tsx scripts/seed-transport.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "analyze": "ANALYZE=true next build --webpack"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
